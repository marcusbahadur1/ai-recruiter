# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname
TEST_DATABASE_URL=postgresql+asyncpg://user:password@host:6543/dbname

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# ── AI providers ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
OPENAI_API_KEY=sk-proj-...          # optional

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Email ─────────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG....
IMAP_HOST=mail.yourdomain.com
IMAP_PORT=993
IMAP_MASTER_PASSWORD=your-imap-password

# ── Email test mode ───────────────────────────────────────────────────────────
# When EMAIL_TEST_MODE=true all outreach emails are redirected to EMAIL_TEST_RECIPIENT.
# A warning banner is prepended showing the original candidate address.
# Set to false (or remove) for production.
EMAIL_TEST_MODE=true
EMAIL_TEST_RECIPIENT=you@example.com

# ── Candidate search ──────────────────────────────────────────────────────────
SCRAPINGDOG_API_KEY=your-scrapingdog-key
BRIGHTDATA_API_KEY=your-brightdata-key

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-key

# ── Super admin ───────────────────────────────────────────────────────────────
# Email that bypasses Supabase role check — lets you access super admin before
# the JWT app_metadata.role is set. Remove once the role is properly assigned.
SUPER_ADMIN_EMAIL=you@yourdomain.com

# ── App ───────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
ENVIRONMENT=development   # development | staging | production
