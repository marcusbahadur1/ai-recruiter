# ─────────────────────────────────────────────────────────────────────────────
# Environment variable template — copy to .env and fill in values.
#
# Real values (with all secrets) are stored in your password manager under:
#   "AI Recruiter — Staging env vars"    (.env-staging, gitignored)
#   "AI Recruiter — Production env vars" (.env-production, gitignored)
#
# Quick switch:
#   cp backend/.env-staging backend/.env     # staging (test Stripe, EMAIL_TEST_MODE)
#   cp backend/.env-production backend/.env  # production (live Stripe, real emails)
# ─────────────────────────────────────────────────────────────────────────────

ENVIRONMENT=staging|production

# ── Supabase ──────────────────────────────────────────────────────────────────
# Staging project:    ydizybmxfesbfkqpvbzr (ap-southeast-1)
# Production project: vigtvsdwbkspkqohvjna (ap-southeast-2, Sydney)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_KEY=              # Project Settings → API → service_role key
SUPABASE_ANON_KEY=                 # Project Settings → API → anon key

# ── Database (use transaction pooler port 6543, NOT session pooler 5432) ──────
SQLALCHEMY_DATABASE_URL=postgresql+asyncpg://postgres.<project-ref>@aws-1-<region>.pooler.supabase.com:6543/postgres
DB_PASSWORD=                       # Stored separately to avoid URL-encoding issues with special chars
TEST_DATABASE_URL=postgresql+asyncpg://postgres.<project-ref>@aws-1-<region>.pooler.supabase.com:6543/postgres

# ── AI providers ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                 # console.anthropic.com → API Keys
OPENAI_API_KEY=                    # platform.openai.com → API Keys

# ── Stripe ────────────────────────────────────────────────────────────────────
# Staging:    test keys (sk_test_..., pk_test_...)
# Production: live keys (sk_live_..., pk_live_...)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=             # Developers → Webhooks → signing secret
STRIPE_PRICE_RECRUITER=            # Staging: price_1TKTz6... / Production: price_1TNh7sCswDd1GeWoz9NU75Wy
STRIPE_PRICE_AGENCY_SMALL=         # Staging: price_1TKTzl... / Production: price_1TNh7tCswDd1GeWou4nphUOh
STRIPE_PRICE_AGENCY_MEDIUM=        # Staging: price_1TKU0P... / Production: price_1TNh7uCswDd1GeWo3JUbJrlt

# ── Email ─────────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=                  # app.sendgrid.com → Settings → API Keys
SENDGRID_FROM_EMAIL=marcus.bahadur@aiworkerz.com
IMAP_HOST=privateemail.com
IMAP_PORT=993
IMAP_MASTER_PASSWORD=              # Namecheap Private Email master credential

# Staging only — redirect all outbound email, never contact real candidates
# EMAIL_TEST_MODE=true
# EMAIL_TEST_RECIPIENT=marcus.bahadur@aiworkerz.com

# ── External APIs ─────────────────────────────────────────────────────────────
SCRAPINGDOG_API_KEY=               # app.scrapingdog.com → Dashboard
BRIGHTDATA_API_KEY=                # brightdata.com → Account → API Token
ENCRYPTION_KEY=                    # Fernet key — generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# ── App ───────────────────────────────────────────────────────────────────────
FRONTEND_URL=                      # Staging: https://frontend-snowy-one-54.vercel.app / Production: https://app.airecruiterz.com
SUPER_ADMIN_EMAIL=marcus@aiworkerz.com
# Local dev: redis://localhost:6379/0
# Railway production: redis://default:<password>@redis.railway.internal:6379
REDIS_URL=redis://localhost:6379/0

# ── AI Marketing Module ───────────────────────────────────────────────────────
# Register at developer.linkedin.com → My Apps → Create App
# Add BOTH redirect URIs to the app:
#   https://api.airecruiterz.com/api/v1/marketing/linkedin/callback   (production)
#   https://api-staging.up.railway.app/api/v1/marketing/linkedin/callback  (staging)
#   http://localhost:8000/api/v1/marketing/linkedin/callback            (local dev)
LINKEDIN_CLIENT_ID=                # LinkedIn app client ID
LINKEDIN_CLIENT_SECRET=            # LinkedIn app client secret
LINKEDIN_REDIRECT_URI=             # Full callback URL for this environment (see above)
UNSPLASH_ACCESS_KEY=               # unsplash.com/oauth/applications → Access Key
